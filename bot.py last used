        coins=sorted(coins,key=lambda x:x["volume_24h"],reverse=True)[:CMC_TOP_COINS]
        logger.info("Kraken: "+str(len(coins))+" coins"); return coins
    except Exception as e: logger.error("Kraken: "+str(e)); return []

