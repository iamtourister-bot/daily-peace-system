            if data:
                data = list(reversed(data))
                return [[float(c[2]),float(c[3]),float(c[4]),float(c[5]),float(c[6])] for c in data]
        except Exception as e: logger.warning("Bybit " + symbol + " " + interval + ": " + str(e))
    return []

