# ============================================================
# HELPER FUNCTIONS — handle BOTH old and new missed_trade formats
# Old records use was_correct (True/False/None)
# New records use outcome ("would_win","would_lose","neutral","expired")
# These helpers preserve historical 251 correct blocks and 209 wrong blocks
# ============================================================
def is_correct_block(t):
    """Block was correct if price went DOWN >1% after we blocked.
    Uses outcome_pct directly — works for both old and new records."""
    pct = t.get("outcome_pct", 0)
    # If outcome_pct exists and is < -1, it was a correct block (price fell)
    if pct < -1:
        return True
    # Pure new-format check: explicit would_lose
    if t.get("outcome") == "would_lose":
        return True
    return False

def is_wrong_block(t):
    """Block was wrong if price went UP >1% after we blocked (missed profit)."""
    pct = t.get("outcome_pct", 0)
    if pct > 1:
        return True
    if t.get("outcome") == "would_win":
        return True
    return False

def is_expired_block(t):
    """Block expired or price barely moved — no clear outcome."""
    outcome = t.get("outcome")
    if outcome in ["expired", "neutral"]: return True
    # If price barely moved (between -1% and +1%) AND outcome was assigned, it's neutral
    pct = t.get("outcome_pct", 0)
    if outcome not in [None, "unknown"] and -1 <= pct <= 1:
        return True
    return False

def is_pending_block(t):
    """Block hasn't been resolved yet."""
    outcome = t.get("outcome")
    if outcome in [None, "unknown"]:
        # was_correct still None means we haven't checked yet
        if t.get("was_correct") is None:
            return True
    return False

def update_missed_trade_outcomes():
    now = datetime.now(timezone.utc)
    updated = False
    # Iterate over snapshot copy — prevents mutation during iteration
    with _brain_lock:
        trades_to_check = list(missed_trades)
    for trade in trades_to_check:
        if trade.get("outcome") != "unknown": continue
        blocked_at = trade.get("blocked_at", "")
        if not blocked_at: continue
        try:
            blocked_time = datetime.fromisoformat(blocked_at)
            hours_since  = (now - blocked_time).total_seconds() / 3600
            if hours_since < 1: continue
            if hours_since > 168:
                trade["outcome"] = "expired"; trade["was_correct"] = None; updated = True; continue
            symbol    = trade["symbol"]; direction = trade["direction"]; entry = trade.get("entry", 0)
            if entry <= 0: continue
            candles = get_candles(symbol, "1h", 1)
            if not candles: continue
            current_price = candles[-1][3]
            if direction == "short":
                pct_move = round((entry - current_price) / entry * 100, 2)
            else:
                pct_move = round((current_price - entry) / entry * 100, 2)
            trade["outcome_pct"] = pct_move
            trade["was_correct"] = pct_move < 0
            trade["outcome"] = "would_win" if pct_move > 1 else "would_lose" if pct_move < -1 else "neutral"
            updated = True
            # Wrong block learning — penalize checks that blocked winning trades
            if not trade["was_correct"] and pct_move > 1:
                for ck in trade.get("failed_checks", []):
                    if ck in check_tag_stats:
                        check_tag_stats[ck]["losses"] += 1
                if trade.get("failed_checks"):
                    try: save_json("check_tags.json", check_tag_stats)
                    except Exception as e: logger.error("Save check_tags: "+str(e))
            logger.info("Missed trade outcome: " + symbol + " " + ("CORRECT block" if trade["was_correct"] else "WRONG block — missed " + str(pct_move) + "%"))
        except Exception as e:
            logger.error("Missed trade update: " + str(e))
    if updated:
        try: save_json("missed_trades.json", missed_trades)
        except Exception as e: logger.error("Save missed_trades: "+str(e))

