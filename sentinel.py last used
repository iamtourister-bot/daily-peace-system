# CHECK SUGGESTED TRADE OUTCOMES — UNCHANGED TRADING LOGIC
# + ANALYTICAL UPGRADE: update brain stats (sentinel_wins/losses)
# ============================================================
def check_suggested_trade_outcomes():
    global suggested_trades, sentinel_brain, coin_confidence, entry_learning
    if not suggested_trades: return
    changed=False

    # Iterate over a SHALLOW COPY to prevent RuntimeError if list is
    # modified by Flask routes (/filled, /outcome) during iteration
    with _brain_lock:
        trades_snapshot = list(suggested_trades)

    for t in trades_snapshot:
        sym=t["symbol"]; direction=t.get("direction","long"); stop=t.get("stop",0); tp1=t.get("tp1",0)
        try:
            r2=_session_binance.get("https://api.binance.com/api/v3/ticker/price",params={"symbol":sym+"USDT"},timeout=5)
            price=float(r2.json().get("price",0)) if r2.status_code==200 else 0
        except: continue
        if not price: continue

        # PHASE 1: PENDING FILL
        if t.get("outcome")=="pending_fill":
            limit_e=t.get("limit_entry",0)
            if not limit_e: continue
            try: age_h=(datetime.now(timezone.utc)-datetime.fromisoformat(t["time"])).total_seconds()/3600
            except: age_h=0
            if age_h>48:
                t["outcome"]="expired_no_fill"; logger.info("Limit expired unfilled: "+sym+" "+direction); changed=True; continue
            filled=False
            if direction=="long" and price<=limit_e*1.0015: filled=True
            elif direction=="short" and price>=limit_e*0.9985: filled=True
            if filled:
                t["outcome"]="pending"; t["entry"]=price; t["peak"]=price
                t["fill_time"]=datetime.now(timezone.utc).isoformat()
                dist_from_limit=round(abs(price-limit_e)/limit_e*100,4); t["fill_dist"]=dist_from_limit
                logger.info("Limit FILLED: "+sym+" "+direction+" @ $"+str(price)+" (limit was $"+str(limit_e)+", dist "+str(dist_from_limit)+"%)")
                changed=True
                # Immediate stop check
                immediate_stop=False
                if direction=="long" and stop>0 and price<=stop: immediate_stop=True
                elif direction=="short" and stop>0 and price>=stop: immediate_stop=True
                if immediate_stop:
                    t["outcome"]="LOSS"; t["close_price"]=price; t["close_time"]=datetime.now(timezone.utc).isoformat()
                    logger.info("IMMEDIATE STOP after fill: "+sym+" "+direction)
                    if not _paused:
                        send_message("❌ <b>Stop hit on fill: "+sym+" "+direction.upper()+"</b>"+chr(10)+
                            "Price filled at $"+str(round(price,6))+" and immediately hit stop $"+str(stop)+chr(10)+"Recorded as LOSS.")
                else:
                    if not _paused:
                        send_message("✅ <b>Limit filled: "+sym+" "+direction.upper()+"</b>"+chr(10)+
                            "Entry: $"+str(round(price,6))+chr(10)+"Stop: $"+str(stop)+" | TP1: $"+str(tp1)+chr(10)+"Now watching...")
                    continue
            else:
                continue

        # PHASE 2: ACTIVE
        if t.get("outcome")!="pending": continue
        entry=t.get("entry",0)
        if not entry: continue

        # ── STALE TRADE EXPIRY ───────────────────────────────────────────
        # Filled trades with no TP/Stop hit after 48h are force-resolved.
        # This clears the 141 stuck "filled live" trades that were:
        # - from the reversed-stop bug (would never hit TP or Stop)
        # - from trades where price drifted and neither level was reached
        # Resolution: compare current price vs entry to determine WIN/LOSS
        fill_time_str = t.get("fill_time", t.get("time", ""))
        if fill_time_str:
            try:
                fill_time = datetime.fromisoformat(fill_time_str)
                hours_filled = (datetime.now(timezone.utc) - fill_time).total_seconds() / 3600
                if hours_filled >= 48:
                    # Force resolve based on current price vs entry
                    if direction == "long":
                        pnl_pct = round((price - entry) / entry * 100, 2)
                    else:
                        pnl_pct = round((entry - price) / entry * 100, 2)
                    t["outcome"] = "WIN" if pnl_pct > 0 else "LOSS"
                    t["close_price"] = price
                    t["close_time"] = datetime.now(timezone.utc).isoformat()
                    t["exit_reason"] = "stale_48h"
                    logger.info("STALE RESOLVE: "+sym+" "+direction+" @ $"+str(price)+
                                " filled "+str(round(hours_filled,1))+"h ago | "+t["outcome"]+" ("+str(pnl_pct)+"%)")
                    if not _paused:
                        send_message("⏰ <b>Stale trade resolved: "+sym+" "+direction.upper()+"</b>"+chr(10)+
                            "Open "+str(round(hours_filled,1))+"h with no TP/Stop hit."+chr(10)+
                            "Resolved at current price: "+("WIN ✅" if t["outcome"]=="WIN" else "LOSS ❌")+chr(10)+
                            "Entry: $"+str(round(entry,6))+" → Now: $"+str(round(price,6))+" ("+str(pnl_pct)+"%)")
                    changed = True
            except Exception as e:
                logger.error("Stale resolve: "+str(e))
        # ────────────────────────────────────────────────────────────────

        if direction=="long":
            if price>t.get("peak",entry): t["peak"]=price
            hit_tp=price>=tp1; hit_stop=price<=stop
        else:
            if price<t.get("peak",entry): t["peak"]=price
            hit_tp=price<=tp1; hit_stop=price>=stop
        if hit_tp: t["outcome"]="WIN"; t["close_price"]=price; t["close_time"]=datetime.now(timezone.utc).isoformat()
        elif hit_stop:
            t["outcome"]="LOSS"; t["close_price"]=price; t["close_time"]=datetime.now(timezone.utc).isoformat()
            # ── POST-TRADE DIAGNOSIS ENGINE ──────────────────────────────────
            # Start background diagnosis immediately on every loss
            # Checks at 30min and 2h to understand WHY the trade failed
            try: start_diagnosis(t)
            except Exception as e: logger.error("Diagnosis start: "+str(e))
            # ────────────────────────────────────────────────────────────────

        # RESOLVE
        if t["outcome"] in ["WIN","LOSS"]:
            is_win=t["outcome"]=="WIN"; nl=chr(10)
            # Only count in brain stats if NOT a stale resolution
            # Stale trades (48h+) are data cleanup, not fresh validated signals
            is_stale = t.get("exit_reason") == "stale_48h"

            # Update brain stats — analytical source split
            sentinel_brain["total_verdicts"]=sentinel_brain.get("total_verdicts",0)+1
            sentinel_brain["approved"]=sentinel_brain.get("approved",0)+1
            if is_win:
                sentinel_brain["approved_wins"]=sentinel_brain.get("approved_wins",0)+1
                sentinel_brain["sentinel_wins"]=sentinel_brain.get("sentinel_wins",0)+1
                if not is_stale:
                    sentinel_brain["clean_era_wins"]=sentinel_brain.get("clean_era_wins",0)+1
                    sentinel_brain["clean_era_sentinel_wins"]=sentinel_brain.get("clean_era_sentinel_wins",0)+1
            else:
                sentinel_brain["approved_losses"]=sentinel_brain.get("approved_losses",0)+1
                sentinel_brain["sentinel_losses"]=sentinel_brain.get("sentinel_losses",0)+1
                if not is_stale:
                    sentinel_brain["clean_era_losses"]=sentinel_brain.get("clean_era_losses",0)+1
                    sentinel_brain["clean_era_sentinel_losses"]=sentinel_brain.get("clean_era_sentinel_losses",0)+1
            save_json("sentinel_brain.json",sentinel_brain)

            # Update coin confidence
            if sym not in coin_confidence:
                coin_confidence[sym]={"long_wins":0,"long_losses":0,"short_wins":0,"short_losses":0}
            key=direction+("_wins" if is_win else "_losses")
            coin_confidence[sym][key]=coin_confidence[sym].get(key,0)+1
            save_json("coin_confidence.json",coin_confidence)

            # Entry quality learning
            if sym not in entry_learning: entry_learning[sym]={}
            if direction not in entry_learning[sym]:
                entry_learning[sym][direction]={"wins":0,"losses":0,"avg_dist":0.0,"total_dist":0.0}
            el=entry_learning[sym][direction]
            if is_win: el["wins"]=el.get("wins",0)+1
            else: el["losses"]=el.get("losses",0)+1
            fill_dist=t.get("fill_dist",0.0)
            el["total_dist"]=el.get("total_dist",0.0)+fill_dist
            total_entries=el["wins"]+el["losses"]
            el["avg_dist"]=round(el["total_dist"]/total_entries,4) if total_entries>0 else 0
            save_json("entry_learning.json",entry_learning)

            el_rate=round(el["wins"]/total_entries*100) if total_entries>0 else 0
            limit_e=t.get("limit_entry",entry); pnl_pct=round(abs(price-entry)/entry*100*(1 if is_win else -1),2)
            if not _paused:
                send_message(("✅" if is_win else "❌")+" <b>Auto-Learn: "+sym+" "+t["outcome"]+"</b>"+nl+
                    "Limit: $"+str(limit_e)+" → Fill: $"+str(round(entry,6))+" → Exit: $"+str(round(price,6))+nl+
                    ("+" if pnl_pct>=0 else "")+str(pnl_pct)+"%"+nl+nl+
                    "📚 "+sym+" "+direction+" entry accuracy: "+str(el_rate)+"% ("+str(total_entries)+" trades)"+nl+
                    "🎯 Avg fill dist from S/R: "+str(el["avg_dist"])+"% — "+("Good level ✅" if el_rate>=60 else "Level under review ⚠️"))
            logger.info("Auto-learn: "+sym+" "+t["outcome"]+" | entry acc: "+str(el_rate)+"%")
            changed=True

    if changed:
        save_json("suggested_trades.json",suggested_trades)

