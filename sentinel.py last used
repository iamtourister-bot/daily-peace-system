def get_liquidity_clusters(symbol, current_price=0):
    """
    3-source liquidity intelligence using data confirmed working on Railway:
    Source 1: sr_touch_map — brain accumulated S/R touch data (proven price magnets)
    Source 2: Open Interest — fapi.binance.com (confirmed working)
    Source 3: Funding Rate — fapi.binance.com (confirmed working)
    """
    result = {
        "symbol":         symbol,
        "current_price":  current_price,
        "above":          [],
        "below":          [],
        "sweep_likely":   "",
        "open_interest":  0,
        "oi_change":      0,
        "funding_rate":   0,
        "funding_bias":   "neutral",
        "market_context": "",
        "scanned_at":     datetime.now(timezone.utc).strftime("%H:%M UTC")
    }
    try:
        sym_pair = symbol + "USDT"
        if current_price <= 0:
            ck = coin_knowledge.get(symbol, {})
            current_price = ck.get("current_price", 0)
        result["current_price"] = current_price

        # SOURCE 1: SR TOUCH MAP
        tm = sr_touch_map.get(symbol, {})
        if current_price > 0:
            above_levels = []
            below_levels = []
            for lvl in tm.get("resistance", []):
                p = lvl.get("level", 0); t = lvl.get("touches", 0)
                if t < 2 or p <= 0: continue
                dist = abs(p - current_price) / current_price
                if dist > 0.25 or p <= current_price: continue
                quality = min(100, round(math.log(t+1) * 15))
                above_levels.append({"price": round(p,4), "touches": t,
                    "quality": quality, "dist_pct": round(dist*100,2),
                    "direction": "above", "nearby": dist <= 0.05})
            for lvl in tm.get("support", []):
                p = lvl.get("level", 0); t = lvl.get("touches", 0)
                if t < 2 or p <= 0: continue
                dist = abs(p - current_price) / current_price
                if dist > 0.25 or p >= current_price: continue
                quality = min(100, round(math.log(t+1) * 15))
                below_levels.append({"price": round(p,4), "touches": t,
                    "quality": quality, "dist_pct": round(dist*100,2),
                    "direction": "below", "nearby": dist <= 0.05})
            above_levels.sort(key=lambda x: x["quality"], reverse=True)
            below_levels.sort(key=lambda x: x["quality"], reverse=True)

            # Fallback: if sr_touch_map has no nearby levels, use coin_knowledge
            # This handles the case where BTC moved to a new price range and
            # the touch map hasn't built up data there yet
            ck_fallback = coin_knowledge.get(symbol, {})
            ck_sup = ck_fallback.get("support", 0)
            ck_res = ck_fallback.get("resistance", 0)
            if not above_levels and ck_res and ck_res > current_price:
                dist = abs(ck_res - current_price) / current_price
                if dist <= 0.10:
                    above_levels.append({"price": round(ck_res,4), "touches": 0,
                        "quality": 30, "dist_pct": round(dist*100,2),
                        "direction": "above", "source": "coin_knowledge"})
            if not below_levels and ck_sup and ck_sup < current_price:
                dist = abs(ck_sup - current_price) / current_price
                if dist <= 0.10:
                    below_levels.append({"price": round(ck_sup,4), "touches": 0,
                        "quality": 30, "dist_pct": round(dist*100,2),
                        "direction": "below", "source": "coin_knowledge"})

            result["above"] = above_levels[:3]
            result["below"] = below_levels[:3]
            if above_levels and below_levels:
                ta = above_levels[0]; tb = below_levels[0]
                as_ = ta["quality"] * (1 - ta["dist_pct"]/8)
                bs_ = tb["quality"] * (1 - tb["dist_pct"]/8)
                if as_ > bs_ and ta["quality"] > 40: result["sweep_likely"] = "above"
                elif bs_ > as_ and tb["quality"] > 40: result["sweep_likely"] = "below"
            elif above_levels and above_levels[0]["quality"] > 40: result["sweep_likely"] = "above"
            elif below_levels and below_levels[0]["quality"] > 40: result["sweep_likely"] = "below"

        # SOURCE 2: OPEN INTEREST
        try:
            r2 = _session_fapi.get("https://fapi.binance.com/fapi/v1/openInterest",
                params={"symbol": sym_pair}, timeout=5)
            if r2.status_code == 200:
                oi = float(r2.json().get("openInterest", 0))
                result["open_interest"] = round(oi * current_price / 1e9, 2) if current_price > 0 else 0
            r2h = _session_fapi.get("https://fapi.binance.com/futures/data/openInterestHist",
                params={"symbol": sym_pair, "period": "1h", "limit": 2}, timeout=5)
            if r2h.status_code == 200:
                hist = r2h.json()
                if len(hist) >= 2:
                    old_oi = float(hist[0].get("sumOpenInterestValue", 0))
                    new_oi = float(hist[1].get("sumOpenInterestValue", 0))
                    if old_oi > 0: result["oi_change"] = round((new_oi-old_oi)/old_oi*100, 2)
        except Exception as e: logger.error("LQ OI "+symbol+": "+str(e))

        # SOURCE 3: FUNDING RATE
