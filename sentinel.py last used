def _path(f): return os.path.join(DATA_DIR, f)

def load_json(filename, default):
    try:
        p = _path(filename)
        if os.path.exists(p):
            with open(p) as f: return json.load(f)
    except Exception: pass
    return default

# Global lock protecting ALL JSON file writes and global dict modifications
# Prevents brain corruption from simultaneous thread writes
_brain_lock = threading.Lock()

def save_json(filename, data):
    try:
        p = _path(filename)
        tmp = p + ".tmp"
        # Write to temp file first then atomic rename
        # This prevents partial writes corrupting the brain
        # Even if bot crashes mid-write, old file survives
        with _brain_lock:
            with open(tmp, "w") as f:
                json.dump(data, f, indent=2)
            os.replace(tmp, p)  # atomic on all platforms
    except Exception as e: logger.error("Save " + filename + ": " + str(e))

