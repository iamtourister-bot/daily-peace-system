def run_historical_backfill():
    """
    Backfill sr_touch_map with historical S/R data.
    Runs ONCE on startup in background thread.
    Fetches daily candles going back 1-2 years and counts
    how many times price interacted with key levels.

    This solves the fundamental problem:
    BTC has well-known levels at $78k, $73k, $69k etc from
    historical trading. Bot was blind to these because it only
    started scanning in March 2026.

    After backfill: brain instantly knows historical S/R levels
    even at price ranges it hasn't scanned in real-time yet.
    """
    # Check if backfill already done to avoid repeating on every restart
    backfill_flag = os.path.join(DATA_DIR, "historical_backfill_done.json")
    if os.path.exists(backfill_flag):
        try:
            flag_data = load_json("historical_backfill_done.json", {})
            # If old backfill used less than 3 years — re-run with full data
            if flag_data.get("years", 0) < 3 or flag_data.get("version", 0) < 4:
                os.remove(backfill_flag)
                logger.info("Backfill flag reset — upgrading to price bucket method")
            else:
                logger.info("Historical backfill already completed (3yr) — skipping")
                return
        except Exception:
            pass

    logger.info("Starting historical S/R backfill (3 years) — runs once...")

    # 3 years = 1095 daily candles
    # Covers full BTC price history:
    #   2023: $15k → $45k
    #   2024: $45k → $108k (ATH)
    #   2025: $78k → $126k (new ATH)
    #   2026: current levels
    # Bot will know every major level smart money remembers
    backfill_coins = {
        "BTC": 1095, "ETH": 1095, "SOL": 1095, "BNB": 1095,
        "XRP": 1095, "LTC": 1095, "BCH": 1095, "DOGE": 1095,
        "ARB": 730,  "LINK": 730,  "AVAX": 730,  "DOT": 730,
        "ADA": 730,  "TRX": 730,  "NEAR": 730,  "ZEC": 730,
    }

    completed = 0
    for symbol, limit in backfill_coins.items():
        try:
            candles = get_candles(symbol, "1d", limit)
            if not candles or len(candles) < 50:
                logger.warning("Backfill: no data for "+symbol)
                continue

            if symbol not in sr_touch_map:
                sr_touch_map[symbol] = {"resistance": [], "support": []}

            # ── PRICE BUCKET APPROACH ─────────────────────────────────────
            # Instead of finding ONE key level per window,
            # count how many candles touched each price zone.
            # This gives EVERY level — $78k, $100k, $126k, $66k — all weighted
            # by how much actual price action happened there.
            #
            # Bucket size:
            #   BTC: $500 wide (round numbers like $78,000 / $78,500)
            #   Alts >$100: $1 wide
            #   Alts $1-$100: $0.10 wide
            #   Micro alts <$1: $0.001 wide

            # Calculate bucket size based on price range
            prices = [c[3] for c in candles]
            avg_price = sum(prices) / len(prices)
            if symbol == "BTC":
                bucket = 500
            elif avg_price > 1000:
                bucket = 10
            elif avg_price > 100:
                bucket = 1
            elif avg_price > 1:
                bucket = 0.1
            else:
                bucket = 0.001

            res_buckets = {}  # price zone → touch count (highs)
            sup_buckets = {}  # price zone → touch count (lows)

            for c in candles:
                high  = c[1]
                low   = c[2]
                # Round to nearest bucket
                res_zone = round(round(high / bucket) * bucket, 6)
                sup_zone = round(round(low  / bucket) * bucket, 6)
                res_buckets[res_zone] = res_buckets.get(res_zone, 0) + 1
                sup_buckets[sup_zone] = sup_buckets.get(sup_zone, 0) + 1

            # Convert buckets to sr_touch_map format
            # Merge with existing data (add to, never overwrite)
            def merge_buckets(level_list, buckets, tolerance_pct=0.002):
                for zone, count in buckets.items():
                    if zone <= 0 or count < 2: continue  # skip noise
                    matched = False
                    for entry in level_list:
                        if abs(entry["level"] - zone) / zone < tolerance_pct:
                            entry["touches"] += count
                            entry["last_seen"] = "historical"
                            matched = True
                            break
                    if not matched:
                        level_list.append({
                            "level":      round(zone, 6),
                            "touches":    count,
                            "first_seen": "historical",
                            "last_seen":  "historical"
                        })

            with _brain_lock:
                merge_buckets(sr_touch_map[symbol]["resistance"], res_buckets)
                merge_buckets(sr_touch_map[symbol]["support"],    sup_buckets)
                # Keep top 30 levels sorted by touches
                sr_touch_map[symbol]["resistance"] = sorted(
                    sr_touch_map[symbol]["resistance"],
                    key=lambda x: x["touches"], reverse=True)[:30]
                sr_touch_map[symbol]["support"] = sorted(
                    sr_touch_map[symbol]["support"],
                    key=lambda x: x["touches"], reverse=True)[:30]

            completed += 1
            logger.info("Backfill: "+symbol+" done | "+
                str(len(sr_touch_map[symbol]["resistance"]))+" res | "+
                str(len(sr_touch_map[symbol]["support"]))+" sup levels"+
                " | price range $"+str(round(min(prices),2))+" - $"+str(round(max(prices),2)))
            time.sleep(0.5)

        except Exception as e:
            logger.error("Backfill "+symbol+": "+str(e))

    # Save updated touch map
    save_json("sr_touch_map.json", sr_touch_map)

    # Mark as done so it never runs again
    save_json("historical_backfill_done.json", {
        "completed_at": datetime.now(timezone.utc).isoformat(),
        "coins_processed": completed,
        "years": 3,
        "version": 4
    })

    logger.info("Historical backfill complete — "+str(completed)+" coins processed")
    if SENTINEL_TOKEN and SENTINEL_CHAT_ID:
        send_message("🧠 <b>Historical S/R Backfill Complete</b>"+chr(10)+
            str(completed)+" coins processed"+chr(10)+
            "Brain now knows historical key levels"+chr(10)+
            "Run /lq BTC to see the improvement.",
            SENTINEL_CHAT_ID)

