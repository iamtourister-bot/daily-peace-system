# ── ASYNC SIGNAL QUEUE ───────────────────────────────────────────────────────
# Bot1 signals are queued and processed in background.
# /analyse returns 200 immediately — never blocks Flask.
# This prevents Telegram commands from freezing during analysis.
_signal_queue = _queue.Queue()

def _signal_worker():
    """Background worker processing Bot1 signals from queue."""
    while True:
        try:
            signal = _signal_queue.get(timeout=5)
            if signal is None: continue
            try:
                symbol    = signal.get("symbol","BTC")
                direction = signal.get("direction","long")
                logger.info("Analysing: "+symbol+" "+direction.upper()+" Bot1:"+str(signal.get("score",0)))
                v = run_sentinel_analysis(signal)
                # Send result back to Bot1 via callback URL if provided
                cb = signal.get("callback_url","")
                if cb:
                    try:
                        _session_bot1.post(cb, json=v, timeout=5)
                    except Exception as e:
                        logger.error("Signal callback: "+str(e))
            except Exception as e:
                logger.error("Signal worker: "+str(e))
            finally:
                _signal_queue.task_done()
        except _queue.Empty:
            continue
        except Exception as e:
            logger.error("Signal worker outer: "+str(e))
