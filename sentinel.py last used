def monitor_open_trades():
    # NOTE: pause only stops NOTIFICATIONS — monitoring always runs to protect trades
    try:
        resp=_session_bot1.get(BOT1_URL+"/trades",timeout=10)
        if resp.status_code!=200: return
        data=resp.json(); trades=data.get("trades",[])
        if not trades: return
        btc_know=coin_knowledge.get("BTC",{}); btc_bias=btc_know.get("bias","NEUTRAL")
        for trade in trades:
            symbol=trade.get("symbol",""); direction=trade.get("direction","long")
            entry=trade.get("entry",0); peak_pnl=trade.get("peak_pnl_pct",0)
            if not symbol or not entry: continue
            price=None
            try:
                r2=_session_binance.get("https://api.binance.com/api/v3/ticker/price",params={"symbol":symbol+"USDT"},timeout=5)
                if r2.status_code==200: price=float(r2.json().get("price",0))
            except: pass
            if not price: continue
            real_pnl=((price-entry)/entry)*100 if direction=="long" else ((entry-price)/entry)*100
            close_reason=None
            if peak_pnl>=0.3 and real_pnl<peak_pnl-0.4:
                close_reason="Peak was +"+str(round(peak_pnl,2))+"% now dropping — locking profit"
            elif peak_pnl>=0.3 and real_pnl<0:
                if direction=="long" and btc_bias=="BEARISH": close_reason="BTC turned bearish — trade was in profit, closing now"
                elif direction=="short" and btc_bias=="BULLISH": close_reason="BTC turned bullish — trade was in profit, closing now"
            if close_reason:
                try:
                    _session_bot1.post(BOT1_URL+"/close/"+symbol,timeout=10)
                    logger.info("SENTINEL CLOSE (PROFIT PROTECT) — "+symbol+" at "+str(round(real_pnl,2))+"% | "+close_reason)
                    if not _paused:
                        send_message("🛡️ <b>Sentinel closing "+symbol+"</b>"+chr(10)+close_reason)
                except Exception as e: logger.error("Close signal failed: "+str(e))
    except Exception as e:
        logger.error("Monitor trades: "+str(e))

# ============================================================
# POST-TRADE DIAGNOSIS ENGINE v1.0
# ============================================================
# After every loss, Sentinel runs a 2-stage background diagnosis:
#
# Stage 1 (30min after close):
#   - Did price bounce quickly after stop hit?
#   - How far did price go against us (PAE)?
#   - Early classification: stop_too_tight or early signal
#
# Stage 2 (2h after close):
#   - Full bounce confirmation with candle data
#   - Find real support level in sr_touch_map
#   - Final diagnosis: type + lesson + coin stats update
#
# Diagnosis types:
#   stop_too_tight   — price bounced quickly, stop needed more room
#   entry_too_far    — fill was far from S/R level, entered at wrong price
#   coin_weak        — no bounce, price kept falling, coin not reliable
#   market_conditions — BTC moved against trade, not coin fault
#   bug_induced      — instant stop, reversed stop, stale close
#
# Storage:
#   trade_diagnoses.json      — per-trade detailed diagnosis
#   coin_diagnosis_stats.json — per-coin aggregated lessons
# ============================================================

def generate_trade_id(symbol, direction, close_time):
    """Unique ID for each diagnosed trade."""
    ts = str(close_time).replace(":", "").replace("-", "").replace("T", "")[:14]
    return symbol + "_" + direction.upper() + "_" + ts

def start_diagnosis(trade):
    """
    Called immediately after a LOSS is recorded.
    Creates pending diagnosis record in trade_diagnoses.json.
    Stage checks run in background via run_diagnosis_checks().
    """
    global trade_diagnoses
    sym       = trade.get("symbol", "")
    direction = trade.get("direction", "long")
    entry     = trade.get("entry", 0)
    stop      = trade.get("stop", 0)
    close_price = trade.get("close_price", 0)
    close_time  = trade.get("close_time", datetime.now(timezone.utc).isoformat())
    limit_entry = trade.get("limit_entry", entry)
    exit_reason = trade.get("exit_reason", "")
    fill_dist   = trade.get("fill_dist", 0.0)

    # Generate unique trade ID
    trade_id = generate_trade_id(sym, direction, close_time)

    # Calculate PAE (Peak Adverse Excursion)
    # How far price moved against us before stop hit
    if entry > 0 and close_price > 0:
        if direction == "long":
            pae_pct = round((entry - close_price) / entry * 100, 3)
        else:
            pae_pct = round((close_price - entry) / entry * 100, 3)
    else:
        pae_pct = 0.0

    # Detect bug-induced losses immediately
    bug_induced = False
    bug_reason  = ""
    trade_open_secs = 0
    try:
        # suggested_trades uses "time" for creation time
        # When limit fills, entry gets set — use close_time vs entry set time
        # Best proxy: if entry > 0 and close happened very fast
        created_time = trade.get("time", trade.get("fill_time", ""))
        if created_time and close_time:
            ft = datetime.fromisoformat(created_time.replace("Z",""))
            ct = datetime.fromisoformat(close_time.replace("Z",""))
            trade_open_secs = (ct - ft).total_seconds()
    except Exception: pass

    if exit_reason == "stale_48h":
        bug_induced = True; bug_reason = "stale_48h_resolution"
    elif pae_pct <= 0.001 and entry > 0:
        bug_induced = True; bug_reason = "reversed_stop_bug"
    elif trade_open_secs > 0 and trade_open_secs < 300:
        bug_induced = True; bug_reason = "instant_stopout_under_5min"

    # Get current market regime
    regime = detect_market_regime()
    regime_name = regime.get("mode", "UNKNOWN") if isinstance(regime, dict) else str(regime)

    # Store pending diagnosis
    record = {
        "trade_id":        trade_id,
        "symbol":          sym,
        "direction":       direction,
        "entry":           entry,
        "stop":            stop,
        "close_price":     close_price,
        "close_time":      close_time,
        "limit_entry":     limit_entry,
        "fill_dist":       fill_dist,
        "pae_pct":         pae_pct,
        "exit_reason":     exit_reason,
        "bug_induced":     bug_induced,
        "bug_reason":      bug_reason,
        "market_regime":   regime_name,
        "diagnosis_version": "1.0",
        "stage":           "bug_skip" if bug_induced else "pending_30m",
        "stage_30m":       {},
        "stage_2h":        {},
        "diagnosis":       {},
        "created_at":      datetime.now(timezone.utc).isoformat()
    }

    # Bug-induced losses get immediate classification without future checks
    if bug_induced:
        record["diagnosis"] = {
            "type":        "bug_induced",
            "pae_pct":     pae_pct,
            "bounced":     False,
            "bug_reason":  bug_reason,
            "lesson":      "Loss caused by system bug ("+bug_reason+") — excluded from coin learning"
        }
        record["stage"] = "complete"
        logger.info("Diagnosis: "+trade_id+" → bug_induced ("+bug_reason+")")

    trade_diagnoses[trade_id] = record
    save_json("trade_diagnoses.json", trade_diagnoses)
    logger.info("Diagnosis started: "+trade_id+" | PAE: "+str(pae_pct)+"% | bug: "+str(bug_induced))
    return trade_id

def run_diagnosis_checks():
    """
    Runs every 15min cycle.
    Processes pending diagnoses at 30min and 2h stages.
    Non-blocking — skips if not enough time has passed.
    """
    global trade_diagnoses, coin_diagnosis_stats
    now     = datetime.now(timezone.utc)
    changed = False

    for trade_id, rec in trade_diagnoses.items():
        stage = rec.get("stage", "complete")
        if stage == "complete" or stage == "bug_skip":
            continue

        close_time_str = rec.get("close_time", "")
        if not close_time_str:
            continue

        try:
            close_dt    = datetime.fromisoformat(close_time_str)
            mins_since  = (now - close_dt).total_seconds() / 60
        except Exception:
            continue

        sym       = rec["symbol"]
        direction = rec["direction"]
        entry     = rec["entry"]
        stop      = rec["stop"]
        close_price = rec["close_price"]
        pae_pct   = rec["pae_pct"]
        fill_dist = rec["fill_dist"]

        # ── STAGE 1: 30 MINUTE CHECK ─────────────────────────────────
        if stage == "pending_30m" and mins_since >= 30:
            try:
                candles = get_candles(sym, "15m", 12)
                if candles and len(candles) >= 4:
                    # Get prices after stop hit (last 4 candles = ~1h)
                    post_closes  = [c[3] for c in candles[-4:]]
                    post_lows    = [c[2] for c in candles[-4:]]
                    current_price = candles[-1][3]

                    if direction == "long":
                        lowest_after   = min(post_lows)
                        recovery       = current_price - lowest_after
                        recovery_pct   = round(recovery / lowest_after * 100, 2) if lowest_after > 0 else 0
                        bounced_30m    = current_price > close_price * 1.01  # recovered >1%
                    else:
                        highest_after  = max([c[1] for c in candles[-4:]])
                        recovery       = highest_after - current_price
                        recovery_pct   = round(recovery / highest_after * 100, 2) if highest_after > 0 else 0
                        bounced_30m    = current_price < close_price * 0.99

                    rec["stage_30m"] = {
                        "completed_at":     now.isoformat(),
                        "price_30m":        round(current_price, 6),
                        "bounced_30m":      bounced_30m,
                        "recovery_pct_30m": recovery_pct
                    }
                    rec["stage"] = "pending_2h"
                    changed = True
                    logger.info("Diagnosis 30m: "+trade_id+" | bounced: "+str(bounced_30m)+" | recovery: "+str(recovery_pct)+"%")
            except Exception as e:
                logger.error("Diagnosis 30m "+trade_id+": "+str(e))

        # ── STAGE 2: 2 HOUR CHECK ────────────────────────────────────
        elif stage == "pending_2h" and mins_since >= 120:
            try:
                candles = get_candles(sym, "15m", 20)
                if candles and len(candles) >= 8:
                    post_closes = [c[3] for c in candles[-8:]]
                    post_lows   = [c[2] for c in candles[-8:]]
                    post_highs  = [c[1] for c in candles[-8:]]
                    current_price = candles[-1][3]

                    if direction == "long":
                        lowest_after  = min(post_lows)
                        recovery_pct  = round((current_price - lowest_after) / lowest_after * 100, 2) if lowest_after > 0 else 0
                        bounced_full  = recovery_pct > 1.0
                        # Find bounce timing — which candle was the low
                        low_idx       = post_lows.index(lowest_after)
                        bounce_mins   = round((len(post_lows) - low_idx) * 15)
                    else:
                        highest_after = max(post_highs)
                        recovery_pct  = round((highest_after - current_price) / highest_after * 100, 2) if highest_after > 0 else 0
                        bounced_full  = recovery_pct > 1.0
                        high_idx      = post_highs.index(highest_after)
                        bounce_mins   = round((len(post_highs) - high_idx) * 15)

                    # Find real support level from sr_touch_map
                    bounce_level   = 0
                    bounce_touches = 0
                    tm = sr_touch_map.get(sym, {})
                    level_type = "support" if direction == "long" else "resistance"
                    ref_price  = lowest_after if direction == "long" else highest_after
                    if ref_price > 0:
                        candidates = [l for l in tm.get(level_type, [])
                                      if abs(l.get("level",0) - ref_price) / ref_price < 0.015
                                      and l.get("touches", 0) >= 10]
                        if candidates:
                            best = max(candidates, key=lambda x: x.get("touches",0))
                            bounce_level   = best.get("level", 0)
                            bounce_touches = best.get("touches", 0)

                    rec["stage_2h"] = {
                        "completed_at":   now.isoformat(),
                        "price_2h":       round(current_price, 6),
                        "bounced_full":   bounced_full,
                        "recovery_pct":   recovery_pct,
                        "bounce_mins":    bounce_mins,
                        "bounce_level":   round(bounce_level, 6),
                        "bounce_touches": bounce_touches
                    }

                    # ── FINAL DIAGNOSIS ──────────────────────────────
                    # Determine diagnosis type from evidence
                    diag_type = "unknown"
                    lesson    = ""

                    # Check if BTC was moving against trade (market conditions)
                    btc_ck    = coin_knowledge.get("BTC", {})
                    btc_bias  = btc_ck.get("overall_bias", "NEUTRAL")
                    btc_against = (direction == "long" and btc_bias == "BEARISH") or \
                                  (direction == "short" and btc_bias == "BULLISH")

                    if bounced_full and pae_pct < 0.5:
                        diag_type = "stop_too_tight"
                        lesson = ("Stop was too tight — price only moved " + str(pae_pct) +
                                  "% before bouncing " + str(recovery_pct) + "% in " +
                                  str(bounce_mins) + "min. " +
                                  ("Real support at $" + str(bounce_level) + " (" + str(bounce_touches) + "x tested). " if bounce_level else "") +
                                  "Next entry: place stop below $" + str(round(bounce_level * 0.998, 6) if bounce_level else round(stop * 0.995, 6)))

                    elif bounced_full and fill_dist > 0.1:
                        diag_type = "entry_too_far"
                        lesson = ("Entry was " + str(fill_dist) + "% from S/R level — too far from support. " +
                                  "Price bounced " + str(recovery_pct) + "% from real level $" + str(bounce_level) + ". " +
                                  "Next entry: only enter within 0.05% of exact support level.")

                    elif not bounced_full and btc_against:
                        diag_type = "market_conditions"
                        lesson = ("BTC was " + btc_bias + " — market moved against " + direction + " trade. " +
                                  "Price did not recover significantly (" + str(recovery_pct) + "%). " +
                                  "Not coin fault — check BTC bias before entering " + sym + ".")

                    elif not bounced_full:
                        diag_type = "coin_weak"
                        lesson = ("Price did not bounce after stop hit — moved " + str(recovery_pct) +
                                  "% in " + str(bounce_mins) + "min. " +
                                  "Support level did not hold. " + sym +
                                  " may need more tested levels before trading again.")

                    else:
                        diag_type = "stop_too_tight"
                        lesson = ("Price bounced " + str(recovery_pct) + "% after stop. " +
                                  "Stop at $" + str(rec["stop"]) + " was slightly too tight.")

                    rec["diagnosis"] = {
                        "type":              diag_type,
                        "pae_pct":           pae_pct,
                        "bounced":           bounced_full,
                        "bounce_recovery_pct": recovery_pct,
                        "bounce_within_mins":  bounce_mins,
                        "bounce_level":        round(bounce_level, 6),
                        "bounce_level_touches": bounce_touches,
                        "entry_dist_pct":    fill_dist,
                        "bug_induced":       False,
                        "btc_against":       btc_against,
                        "lesson":            lesson
                    }
                    rec["stage"] = "complete"
                    changed = True

                    # ── UPDATE COIN DIAGNOSIS STATS ──────────────────
                    if sym not in coin_diagnosis_stats:
                        coin_diagnosis_stats[sym] = {
                            "stop_too_tight":    0,
                            "entry_too_far":     0,
                            "coin_weak":         0,
                            "market_conditions": 0,
                            "bug_induced":       0,
                            "total_diagnosed":   0,
                            "total_bounced":     0,
                            "bounce_rate":       0.0,
                            "avg_pae":           0.0,
                            "total_pae":         0.0
                        }
                    ds = coin_diagnosis_stats[sym]
                    ds[diag_type] = ds.get(diag_type, 0) + 1
                    ds["total_diagnosed"] = ds.get("total_diagnosed", 0) + 1
                    if bounced_full: ds["total_bounced"] = ds.get("total_bounced", 0) + 1
                    ds["total_pae"]  = round(ds.get("total_pae", 0) + pae_pct, 4)
                    ds["avg_pae"]    = round(ds["total_pae"] / ds["total_diagnosed"], 3)
                    ds["bounce_rate"] = round(ds["total_bounced"] / ds["total_diagnosed"], 3)
                    save_json("coin_diagnosis_stats.json", coin_diagnosis_stats)

                    logger.info("Diagnosis complete: "+trade_id+" → "+diag_type+" | bounced: "+str(bounced_full))

                    # ── NOTIFY USER ──────────────────────────────────
                    nl = chr(10)
                    bounce_str = ("✅ YES — recovered +" + str(recovery_pct) + "% in " + str(bounce_mins) + "min" if bounced_full
                                  else "❌ NO — price kept falling (" + str(recovery_pct) + "% recovery only)")
                    level_str  = ("📍 Bounce from $" + str(round(bounce_level, 4)) +
                                  " (" + str(bounce_touches) + "x tested in brain)" if bounce_level else "📍 No known support at bounce level")
                    icon = {"stop_too_tight": "⚠️", "entry_too_far": "🎯",
                            "coin_weak": "🚫", "market_conditions": "🌍", "bug_induced": "🐛"}.get(diag_type, "🔬")

                    if not _paused:
                        send_message(
                            "🔬 <b>Post-Trade Diagnosis: " + sym + " " + direction.upper() + " LOSS</b>" + nl + nl +
                            "📊 <b>What happened:</b>" + nl +
                            "  Entry: $" + str(round(rec["entry"], 6)) + nl +
                            "  Stop hit: $" + str(round(rec["close_price"], 6)) + nl +
                            "  Price moved: -" + str(pae_pct) + "% before stop" + nl + nl +
                            "🔄 <b>After stop hit:</b>" + nl +
                            "  Bounced: " + bounce_str + nl +
                            "  " + level_str + nl + nl +
                            icon + " <b>Diagnosis: " + diag_type.upper().replace("_", " ") + "</b>" + nl +
                            "💡 " + lesson + nl + nl +
                            "📈 <b>" + sym + " diagnosis history:</b>" + nl +
                            "  Stop too tight: " + str(ds.get("stop_too_tight", 0)) + "x" + nl +
                            "  Entry too far:  " + str(ds.get("entry_too_far", 0)) + "x" + nl +
                            "  Coin weak:      " + str(ds.get("coin_weak", 0)) + "x" + nl +
                            "  Market cond:    " + str(ds.get("market_conditions", 0)) + "x" + nl +
                            "  Bounce rate:    " + str(round(ds["bounce_rate"] * 100)) + "%" + nl +
                            "  Avg PAE:        " + str(ds["avg_pae"]) + "%" + nl + nl +
                            "⏰ " + now.strftime("%H:%M UTC"))

            except Exception as e:
                logger.error("Diagnosis 2h " + trade_id + ": " + str(e))

    # ── PRE-MOVE THINK OUTCOME TRACKING ─────────────────────────────────────
    # Resolves /think bounce zone suggestions — did the dump happen?
    # Did price reach the suggested level? Did it bounce?
    # This is the learning mechanism that makes /think smarter over time.
    for trade_id, rec in trade_diagnoses.items():
        if rec.get("type") != "pre_move_think": continue
        if rec.get("outcome") != "pending": continue

        created_str = rec.get("created_at", "")
        if not created_str: continue
        try:
            created_dt = datetime.fromisoformat(created_str)
            mins_since = (now - created_dt).total_seconds() / 60
        except Exception: continue

        # Only resolve after 2 hours — enough time for dump + bounce to play out
        if mins_since < 120: continue

        sym             = rec.get("symbol", "")
        suggested_level = rec.get("suggested_level", 0)
        current_price_at_suggest = rec.get("current_price", 0)
        if not sym or not suggested_level: continue

        try:
            candles = get_candles(sym, "15m", 20)
            if not candles or len(candles) < 8: continue

            lows   = [c[2] for c in candles]
            closes = [c[3] for c in candles]
            lowest = min(lows)
            current = closes[-1]

            # Did price actually dump to suggested level?
            dump_happened = lowest <= suggested_level * 1.005  # within 0.5%

            if dump_happened:
                # Did it bounce from that level?
                bounce_pct = round((current - lowest) / lowest * 100, 2) if lowest > 0 else 0
                bounced    = bounce_pct >= 1.0  # recovered at least 1%

                # Update coin_diagnosis_stats with pre_move_think outcome
                if sym not in coin_diagnosis_stats:
                    coin_diagnosis_stats[sym] = {
                        "stop_too_tight": 0, "entry_too_far": 0,
                        "coin_weak": 0, "market_conditions": 0,
                        "bug_induced": 0, "total_diagnosed": 0,
                        "total_bounced": 0, "bounce_rate": 0.0,
                        "avg_pae": 0.0, "total_pae": 0.0,
                        "pm_think_total": 0, "pm_think_bounced": 0,
                        "pm_think_bounce_rate": 0.0
                    }
                ds = coin_diagnosis_stats[sym]
                ds["pm_think_total"]   = ds.get("pm_think_total", 0) + 1
                if bounced: ds["pm_think_bounced"] = ds.get("pm_think_bounced", 0) + 1
                t_pm = ds["pm_think_total"]
                ds["pm_think_bounce_rate"] = round(ds["pm_think_bounced"] / t_pm, 3) if t_pm > 0 else 0.0
                save_json("coin_diagnosis_stats.json", coin_diagnosis_stats)

                rec["outcome"]       = "bounced" if bounced else "dumped_no_bounce"
                rec["lowest_price"]  = round(lowest, 6)
                rec["bounce_pct"]    = bounce_pct
                rec["resolved_at"]   = now.isoformat()

                logger.info("PM think resolved: "+trade_id+" | dump ✅ | bounce: "+str(bounced)+" ("+str(bounce_pct)+"%)")

                # Notify user with outcome
                if not _paused:
                    nl = chr(10)
                    send_message(
                        "🔬 <b>Pre-Move Think: "+sym+" Outcome</b>"+nl+nl+
                        "📍 Suggested bounce level: $"+str(round(suggested_level,4))+nl+
                        "📉 Price reached: $"+str(round(lowest,4))+" ✅"+nl+
                        "📈 Recovery: "+str(bounce_pct)+"%" +nl+nl+
                        ("✅ <b>BOUNCED</b> — Level held! +"+str(bounce_pct)+"% recovery" if bounced
                         else "❌ <b>NO BOUNCE</b> — Price dumped through support")+nl+nl+
                        "🧠 "+sym+" pre-move bounce rate: "+
                        str(round(ds["pm_think_bounce_rate"]*100))+
                        "% ("+str(ds["pm_think_total"])+" predictions)"+nl+
                        "⏰ "+now.strftime("%H:%M UTC"), chat_id=list(chat_ids)[0] if chat_ids else None)
            else:
                # Price never reached the suggested level — no dump happened
                rec["outcome"]     = "no_dump"
                rec["lowest_price"] = round(lowest, 6)
                rec["resolved_at"] = now.isoformat()
                logger.info("PM think resolved: "+trade_id+" | no dump (lowest $"+str(round(lowest,6))+" vs suggested $"+str(suggested_level)+")")

            changed = True

        except Exception as e:
            logger.error("PM think resolution "+trade_id+": "+str(e))
    # ─────────────────────────────────────────────────────────────────────────

    if changed:
        save_json("trade_diagnoses.json", trade_diagnoses)

